<UserControl x:Class="Codeer.LowCode.Blazor.Extras.Designer.Controls.MappingColumnsPropertyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Codeer.LowCode.Blazor.Extras.Designer.ViewModels"
             xmlns:properties="clr-namespace:Codeer.LowCode.Blazor.Extras.Designer.Properties"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance viewModels:MappingColumnsViewModel}">
  <UserControl.Resources>
    <Style x:Key="EditorLabel" TargetType="TextBlock">
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>
    <Style x:Key="DescriptionText" TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Opacity" Value="0.65" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,3,0,10" />
    </Style>
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- 左: 列一覧 (並び順 = ファイルの列位置) / 右: 選択列の詳細 -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="230" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Style="{StaticResource EditorLabel}"
                   Text="{x:Static properties:Resources.MappingColumnListHeader}" TextWrapping="Wrap" />
        <ListBox Grid.Row="1" ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding ListLabel, Mode=OneWay}" Margin="2" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,4,0,0">
          <Button Content="{x:Static properties:Resources.MappingAdd}" Margin="0,0,2,0" Click="AddItem" />
          <Button Content="{x:Static properties:Resources.MappingDelete}" Margin="2,0" Click="DeleteItem" />
          <Button FontFamily="Segoe Fluent Icons" Content="&#xE74A;" Margin="2,0"
                  ToolTip="{x:Static properties:Resources.MappingMoveUp}" Click="MoveUpItem" />
          <Button FontFamily="Segoe Fluent Icons" Content="&#xE74B;" Margin="2,0,0,0"
                  ToolTip="{x:Static properties:Resources.MappingMoveDown}" Click="MoveDownItem" />
        </UniformGrid>
      </Grid>

      <Grid Grid.Column="1" Margin="12,0,0,0">
        <!-- 未選択時のガイド -->
        <TextBlock Text="{x:Static properties:Resources.MappingSelectColumnHint}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Opacity="0.6" TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <!-- 選択列の詳細 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      DataContext="{Binding SelectedItem}">
          <ScrollViewer.Style>
            <Style TargetType="ScrollViewer">
              <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ScrollViewer.Style>
          <StackPanel Margin="0,0,4,0">
            <TextBlock Style="{StaticResource EditorLabel}" Text="{x:Static properties:Resources.MappingExternalName}" />
            <TextBox Text="{Binding ExternalName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Style="{StaticResource DescriptionText}" Text="{x:Static properties:Resources.MappingExternalNameDescription}" />

            <TextBlock Style="{StaticResource EditorLabel}" Text="{x:Static properties:Resources.MappingField}" />
            <ComboBox IsEditable="True"
                      ItemsSource="{Binding DataContext.FieldCandidates, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Text="{Binding Field, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Style="{StaticResource DescriptionText}" Text="{x:Static properties:Resources.MappingFieldDescription}" />

            <TextBlock Style="{StaticResource EditorLabel}" Text="{x:Static properties:Resources.MappingFixedValue}" />
            <TextBox Text="{Binding FixedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Style="{StaticResource DescriptionText}" Text="{x:Static properties:Resources.MappingFixedValueDescription}" />

            <GroupBox Header="{x:Static properties:Resources.MappingCodeConversion}" Padding="8,4" Margin="0,4,0,0">
              <StackPanel>
                <TextBlock Style="{StaticResource DescriptionText}" Margin="0,4,0,10"
                           Text="{x:Static properties:Resources.MappingCodeConversionDescription}" />

                <TextBlock Style="{StaticResource EditorLabel}" Text="{x:Static properties:Resources.MappingConversionModule}" />
                <ComboBox IsEditable="True"
                          ItemsSource="{Binding DataContext.ModuleCandidates, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Text="{Binding ConversionModule, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Style="{StaticResource EditorLabel}" Margin="0,10,0,2"
                           Text="{x:Static properties:Resources.MappingConversionExternalField}" />
                <ComboBox IsEditable="True"
                          ItemsSource="{Binding ConversionFieldCandidates}"
                          Text="{Binding ConversionExternalField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Style="{StaticResource EditorLabel}" Margin="0,10,0,2"
                           Text="{x:Static properties:Resources.MappingConversionInternalField}" />
                <ComboBox IsEditable="True"
                          ItemsSource="{Binding ConversionFieldCandidates}"
                          Text="{Binding ConversionInternalField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
            </GroupBox>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Width="100" Margin="5,0,0,0" Content="OK" Click="OkClick" />
      <Button Width="100" Margin="5,0,0,0" Content="Cancel" Click="CancelClick" />
    </StackPanel>
  </Grid>
</UserControl>
