<UserControl x:Class="Codeer.LowCode.Blazor.Extras.Designer.Controls.TaskBoardStatusesPropertyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Codeer.LowCode.Blazor.Extras.Designer.ViewModels"
             mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="750"
             d:DataContext="{d:DesignInstance viewModels:TaskBoardStatusesViewModel}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Margin="5,5,5,2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition />
        <ColumnDefinition />
        <ColumnDefinition />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Text="DisplayText" FontWeight="Bold" Margin="0,0,3,0" />
      <TextBlock Grid.Column="1" Text="Value" FontWeight="Bold" Margin="0,0,3,0" />
      <TextBlock Grid.Column="2" Text="Color" FontWeight="Bold" Margin="0,0,3,0" />
      <TextBlock Grid.Column="4" Text="BackgroundColor" FontWeight="Bold" Margin="0,0,3,0" />
      <TextBlock Grid.Column="7" Text="CanAdd" FontWeight="Bold" Margin="3,0,3,0" />
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="5,0,5,3">
              <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox Margin="0,0,3,0" Text="{Binding DisplayText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <TextBox Grid.Column="1" Margin="0,0,3,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <TextBox Grid.Column="2" Margin="0,0,3,0" Text="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <Button Grid.Column="3" Margin="0,0,3,0" Width="24" FontFamily="Segoe Fluent Icons" Content="&#xe790;" Command="{Binding ChooseColorCommand}" />
              <TextBox Grid.Column="4" Margin="0,0,3,0" Text="{Binding BackgroundColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <Button Grid.Column="5" Margin="0,0,3,0" Width="24" FontFamily="Segoe Fluent Icons" Content="&#xe790;" Command="{Binding ChooseBackgroundColorCommand}" />
              <Button Grid.Column="6" Margin="0,0,3,0" Width="24" FontFamily="Segoe Fluent Icons" Content="&#xE74A;" Command="{Binding MoveUpCommand}" />
              <CheckBox Grid.Column="7" Margin="3,0,3,0" IsChecked="{Binding CanAdd, Mode=TwoWay}" VerticalAlignment="Center" />
              <Button Grid.Column="8" Width="24" FontFamily="Segoe Fluent Icons" Content="&#xE74D;"
                      Click="DeleteItem" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Button Grid.Row="2" Content="Add" Margin="5,3,5,5" Click="AddItem" />

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
      <Button Width="100" Margin="5,0,0,0" Content="OK" Click="OkClick" />
      <Button Width="100" Margin="5,0,0,0" Content="Cancel" Click="CancelClick" />
    </StackPanel>
  </Grid>
</UserControl>
