@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Codeer.LowCode.Blazor.Components
@using Codeer.LowCode.Blazor.OperatingModel
@using Codeer.LowCode.Blazor.Repository.Design
@using Codeer.LowCode.Blazor.RequestInterfaces
@using Codeer.LowCode.Blazor.Components.Fields
@using Codeer.LowCode.Blazor.Extras.Designs
@using Codeer.LowCode.Blazor.Extras.Fields
@inherits FieldComponentBase<TaskBoardField>
@inject Services Services
@inject IJSRuntime JSRuntime

<div @ref="Element" class="taskboard-container @(_dragItem != null ? "is-dragging" : "")">
  <div class="taskboard-columns">
    @foreach (var status in Field.StatusCategories)
    {
      var statusValue = status.EffectiveValue;
      var columnItems = Field.GetColumnItems(statusValue);
      <div class="taskboard-column"
           @ondragover:preventDefault="true"
           @ondrop="() => OnDropOnColumn(statusValue)">
        <div class="taskboard-column-header" style="@GetHeaderStyle(status)">
          <span class="taskboard-column-title">@status.DisplayText</span>
          <button type="button" class="taskboard-add-btn" style="@(status.CanAdd ? "" : "visibility:hidden")" @onclick="() => OnAddClicked(statusValue)">+</button>
        </div>
        <div class="taskboard-column-body">
          @foreach (var (index, item) in columnItems.Select((item, i) => (i, item)))
          {
            var capturedItem = item;
            var capturedIndex = index;
            var isDragOver = _dragOverStatus == statusValue && _dragOverIndex == capturedIndex;
            @if (isDragOver && _dragOverPosition == DropPosition.Before)
            {
              <div class="taskboard-drop-indicator"></div>
            }
            <div class="taskboard-card @(_dragItem == capturedItem ? "dragging" : "")"
                 draggable="true"
                 @ondragstart="() => OnDragStart(capturedItem, statusValue, capturedIndex)"
                 @ondragend="OnDragEnd"
                 @ondragover="e => UpdateDragOver(statusValue, capturedIndex, DropPosition.After)"
                 @ondragover:preventDefault="true"
                 @ondrop="() => OnDropOnColumn(statusValue)"
                 @ondrop:stopPropagation="true"
                 @ondblclick="() => OnCardDoubleClicked(capturedItem)">
              <div class="taskboard-card-drop-before"
                   @ondragover="() => UpdateDragOver(statusValue, capturedIndex, DropPosition.Before)"
                   @ondragover:preventDefault="true"
                   @ondragover:stopPropagation="true"
                   @ondrop="() => OnDropOnColumn(statusValue)"
                   @ondrop:stopPropagation="true"></div>
              <div class="taskboard-card-drop-after"
                   @ondragover="() => UpdateDragOver(statusValue, capturedIndex, DropPosition.After)"
                   @ondragover:preventDefault="true"
                   @ondragover:stopPropagation="true"
                   @ondrop="() => OnDropOnColumn(statusValue)"
                   @ondrop:stopPropagation="true"></div>
              @if (ModuleDesign is not null)
              {
                <ChildModule Design="@LayoutDesign" ModuleDesign="ModuleDesign" Data="capturedItem.Module" IsTransparent />
              }
            </div>
            @if (isDragOver && _dragOverPosition == DropPosition.After)
            {
              <div class="taskboard-drop-indicator"></div>
            }
          }
          @if (_dragItem != null)
          {
            <div class="taskboard-empty-drop @(_dragOverStatus == statusValue && _dragOverIndex >= columnItems.Count ? "drag-over" : "")"
                 @ondragover="e => UpdateDragOver(statusValue, columnItems.Count, DropPosition.Before)"
                 @ondragover:preventDefault="true"
                 @ondrop="() => OnDropOnColumn(statusValue)"
                 @ondrop:stopPropagation="true">
            </div>
          }
        </div>
      </div>
    }
  </div>
</div>

@code {
  enum DropPosition { Before, After }

  private IJSObjectReference? _jsModule;
  private ModuleDesign? ModuleDesign { get; set; }

  private GridLayoutDesign LayoutDesign
  {
    get
    {
      if (ModuleDesign == null) return new();
      var layoutName = Field.Design.DetailLayoutName;
      if (ModuleDesign.DetailLayouts.TryGetValue(layoutName, out var detail))
        return (GridLayoutDesign)detail.Layout;
      if (!string.IsNullOrEmpty(layoutName) && ModuleDesign.DetailLayouts.TryGetValue(string.Empty, out var defaultDetail))
        return (GridLayoutDesign)defaultDetail.Layout;
      return new();
    }
  }

  private TaskBoardItem? _dragItem;
  private string? _dragSourceStatus;
  private int _dragSourceIndex;
  private string? _dragOverStatus;
  private int _dragOverIndex = -1;
  private DropPosition _dragOverPosition;

  protected override async Task OnParametersSetAsync()
  {
    await base.OnParametersSetAsync();
    var moduleName = Field.Design.SearchCondition.ModuleName;
    if (!string.IsNullOrEmpty(moduleName))
      ModuleDesign = Services.AppInfoService.GetDesignData().Modules.Find(moduleName);
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    await base.OnAfterRenderAsync(firstRender);
    if (firstRender)
    {
      _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
        "import", "./_content/Codeer.LowCode.Blazor.Extras/taskboard-interop.js");
      await _jsModule.InvokeVoidAsync("initTaskBoard", Element);
    }
  }

  public override async ValueTask DisposeAsync()
  {
    if (_jsModule != null)
    {
      try { await _jsModule.DisposeAsync(); } catch { }
    }
    await base.DisposeAsync();
  }

  private static string GetHeaderStyle(TaskBoardStatusDesign status)
  {
    var hasColor = !string.IsNullOrEmpty(status.Color);
    var hasBg = !string.IsNullOrEmpty(status.BackgroundColor);
    if (!hasColor && !hasBg) return string.Empty;
    var parts = new List<string>();
    if (hasBg)
    {
      parts.Add($"background: {status.BackgroundColor}");
      parts.Add($"border-bottom-color: {status.BackgroundColor}");
    }
    if (hasColor)
    {
      parts.Add($"color: {status.Color}");
    }
    return string.Join("; ", parts) + ";";
  }

  private async Task OnAddClicked(string statusValue)
    => await Field.AddAsync(statusValue);

  private async Task OnCardDoubleClicked(TaskBoardItem item)
    => await Field.EditAsync(item.Module);

  private void OnDragStart(TaskBoardItem item, string statusValue, int index)
  {
    _dragItem = item;
    _dragSourceStatus = statusValue;
    _dragSourceIndex = index;
  }

  private void OnDragEnd()
  {
    _dragItem = null;
    _dragSourceStatus = null;
    _dragOverStatus = null;
    _dragOverIndex = -1;
    StateHasChanged();
  }

  private void UpdateDragOver(string statusValue, int index, DropPosition position)
  {
    if (_dragItem == null) return;
    _dragOverStatus = statusValue;
    _dragOverIndex = index;
    _dragOverPosition = position;
    StateHasChanged();
  }

  private async Task OnDropOnColumn(string statusValue)
  {
    if (_dragItem == null) return;

    var item = _dragItem;
    var newIndex = _dragOverIndex;

    if (_dragOverPosition == DropPosition.After) newIndex++;

    if (_dragSourceStatus == statusValue && _dragSourceIndex < newIndex)
    {
      newIndex--;
    }

    if (newIndex < 0) newIndex = 0;

    _dragItem = null;
    _dragSourceStatus = null;
    _dragOverStatus = null;
    _dragOverIndex = -1;

    await Field.MoveTaskAsync(item, statusValue, newIndex);
    StateHasChanged();
  }
}
