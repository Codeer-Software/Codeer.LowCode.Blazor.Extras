@using System.Globalization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Codeer.LowCode.Blazor.Components
@using Codeer.LowCode.Blazor.Extras.Fields
@using Codeer.LowCode.Blazor.Extras.Properties
@inherits FieldComponentBase<GanttField>
@inject IJSRuntime JSRuntime

<div @ref="Element" class="gantt-container" tabindex="0"
     @onkeydown="OnKeyDown" @onclick="OnContainerClick" @oncontextmenu:preventDefault="true">
  @* ===== Toolbar ===== *@
  @if (Field.Design.ShowToolbar)
  {
    <div class="gantt-toolbar">
      <div class="gantt-toolbar-left">
        @if (Field.IsCustomRange)
        {
          @if (Field.Design.CustomRangeEditable)
          {
            <button type="button" class="gantt-range-btn" @onclick="OpenRangePopup">
              @GetTitle()
            </button>
          }
          else
          {
            <span class="gantt-toolbar-title">@GetTitle()</span>
          }
        }
        else
        {
          <button type="button" class="gantt-toolbar-btn gantt-toolbar-btn-today" @onclick="GoToday">@Resources.Today</button>
          <button type="button" class="gantt-toolbar-btn gantt-toolbar-btn-prev" @onclick="GoPrev">&#9664;</button>
          <button type="button" class="gantt-toolbar-btn gantt-toolbar-btn-next" @onclick="GoNext">&#9654;</button>
          <span class="gantt-toolbar-title">@GetTitle()</span>
        }
      </div>
      <div class="gantt-toolbar-right">
        @if (IsEditable)
        {
          <button type="button" class="gantt-toolbar-btn gantt-toolbar-btn-add" @onclick="OnAddClicked">@Resources.Add</button>
        }
        @if (!Field.IsCustomRange && EnabledViewModeCount > 1)
        {
          <div class="gantt-view-switcher">
            @if (Field.IsViewModeEnabled(GanttViewMode.Day))
            {
              <button type="button" class="gantt-view-btn @(Field.ViewMode == GanttViewMode.Day ? "active" : "")"
                      @onclick="() => SetViewMode(GanttViewMode.Day)">@Resources.Day</button>
            }
            @if (Field.IsViewModeEnabled(GanttViewMode.Week))
            {
              <button type="button" class="gantt-view-btn @(Field.ViewMode == GanttViewMode.Week ? "active" : "")"
                      @onclick="() => SetViewMode(GanttViewMode.Week)">@Resources.Week</button>
            }
            @if (Field.IsViewModeEnabled(GanttViewMode.Month))
            {
              <button type="button" class="gantt-view-btn @(Field.ViewMode == GanttViewMode.Month ? "active" : "")"
                      @onclick="() => SetViewMode(GanttViewMode.Month)">@Resources.Month</button>
            }
          </div>
        }
      </div>
    </div>
  }

  @if (_rangePopupOpen)
  {
    <div class="gantt-range-overlay" @onclick="CloseRangePopup">
      <div class="gantt-range-popup" @onclick:stopPropagation="true">
        <div class="gantt-range-popup-row">
          <label class="gantt-range-popup-label">@Resources.GanttFieldCustomRangeStart</label>
          <input type="date" class="gantt-range-input" value="@_rangeEditStart.ToString("yyyy-MM-dd")"
                 @onchange="e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) _rangeEditStart = d; }" />
        </div>
        <div class="gantt-range-popup-row">
          <label class="gantt-range-popup-label">@Resources.GanttFieldCustomRangeEnd</label>
          <input type="date" class="gantt-range-input" value="@_rangeEditEnd.ToString("yyyy-MM-dd")"
                 @onchange="e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) _rangeEditEnd = d; }" />
        </div>
        <div class="gantt-range-popup-buttons">
          <button type="button" class="gantt-range-popup-cancel" @onclick="CloseRangePopup">@Resources.Cancel</button>
          <button type="button" class="gantt-range-popup-ok" @onclick="ApplyRangePopup">@Resources.OK</button>
        </div>
      </div>
    </div>
  }

  @* ===== Gantt Body ===== *@
  <div class="gantt-body">
    @{
      var lp = CalcLayout();
    }

    @* ===== Left: Task labels ===== *@
    <div class="gantt-labels">
      <div class="gantt-label-header" style="height: @Px(lp.HeaderHeight);">
        <span>@Resources.Task</span>
      </div>
      <div class="gantt-label-body">
        @foreach (var item in Field.Items)
        {
          <div class="gantt-label-row" style="height: @Px(lp.RowHeight);"
               @onclick="() => OnTaskClicked(item)" title="@item.Text">
            <span class="gantt-label-text">@item.Text</span>
            @if (item.Progress > 0)
            {
              <span class="gantt-label-progress">@item.Progress%</span>
            }
          </div>
        }
      </div>
    </div>

    @* ===== Right: Timeline ===== *@
    <div class="gantt-timeline-scroll" style="background: linear-gradient(to bottom, #f8f9fa @Px(lp.HeaderHeight), #fff @Px(lp.HeaderHeight));">
      <svg class="gantt-timeline-svg"
           width="@F(lp.TimelineWidth)" height="@lp.TotalHeight"
           @onmousemove="OnMouseMove" @onmouseup="OnMouseUp" @onmouseleave="OnMouseUp">

        <defs>
          <marker id="dep-arrow" markerWidth="8" markerHeight="8" refX="7" refY="4"
                  orient="auto" markerUnits="strokeWidth">
            <path d="M0,0 L8,4 L0,8 Z" fill="#6b7280" />
          </marker>
          <marker id="dep-arrow-selected" markerWidth="8" markerHeight="8" refX="7" refY="4"
                  orient="auto" markerUnits="strokeWidth">
            <path d="M0,0 L8,4 L0,8 Z" fill="#ea4335" />
          </marker>
        </defs>

        @RenderHeader(lp)
        @RenderGrid(lp)
        @RenderTodayLine(lp)
        @RenderTaskBars(lp)
        @RenderDependencyArrows(lp)
      </svg>
    </div>
  </div>

  @* ===== Context Menu ===== *@
  @if (_contextMenuVisible)
  {
    <div class="gantt-context-menu-overlay" @onclick="CloseContextMenu">
      <div class="gantt-context-menu" style="left: @Px(_contextMenuX); top: @Px(_contextMenuY);"
           @onclick:stopPropagation="true">
        <div class="gantt-context-menu-item" @onclick="OnContextMenuAddDep">@Resources.AddDependency</div>
      </div>
    </div>
  }
</div>

@code {
  const int RowHeight = 40;
  const int BarPadding = 6;

  enum DragMode { Move, ResizeLeft, ResizeRight }

  private IJSObjectReference? _jsModule;
  private int _containerWidth;

  bool _dragging;
  int _dragIdx;
  DragMode _dragMode;
  double _dragStartX;
  DateTime _dragOrigStart;
  DateTime _dragOrigEnd;

  bool _contextMenuVisible;
  double _contextMenuX;
  double _contextMenuY;
  string? _contextMenuTaskId;
  string? _depLinkingSourceId;
  string? _selectedDepKey;

  private bool IsFitToWidth => Field.Design.FitToWidth || Field.IsCustomRange;
  private bool IsDisabled => Field.IsEnabled == false;
  private bool IsViewMode => Field.IsViewOnly;
  private bool IsEditable => !IsViewMode && !IsDisabled;

  private int EnabledViewModeCount =>
    (Field.IsViewModeEnabled(GanttViewMode.Day) ? 1 : 0) +
    (Field.IsViewModeEnabled(GanttViewMode.Week) ? 1 : 0) +
    (Field.IsViewModeEnabled(GanttViewMode.Month) ? 1 : 0);

  private CultureInfo _culture => CultureInfo.CurrentUICulture;

  private DotNetObjectReference<GanttFieldComponent>? _dotNetRef;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    await base.OnAfterRenderAsync(firstRender);
    if (firstRender && IsFitToWidth)
    {
      _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
        "import", "./_content/Codeer.LowCode.Blazor.Extras/gantt-interop.js");
      _containerWidth = await _jsModule.InvokeAsync<int>("getTimelineWidth", Element);
      _dotNetRef = DotNetObjectReference.Create(this);
      await _jsModule.InvokeVoidAsync("observeResize", Element, _dotNetRef);
      StateHasChanged();
    }
  }

  [JSInvokable]
  public void OnContainerResized(int width)
  {
    if (width == _containerWidth) return;
    _containerWidth = width;
    StateHasChanged();
  }

  public override async ValueTask DisposeAsync()
  {
    if (_jsModule != null)
    {
      try
      {
        await _jsModule.InvokeVoidAsync("disposeResize", Element);
        await _jsModule.DisposeAsync();
      }
      catch { }
    }
    _dotNetRef?.Dispose();
    await base.DisposeAsync();
  }

  private string Px(double v) => v.ToString("0.#", CultureInfo.InvariantCulture) + "px";
  private string F(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

  private const string DefaultBarBaseColor = "#1a73e8";

  // Field value > Design default. Empty means "no inline override".
  private string EffectiveBarColor(GanttItem item)
    => !string.IsNullOrEmpty(item.BarColor) ? item.BarColor : Field.Design.BarColor;

  private string BuildBarStyle(GanttItem item)
  {
    var style = string.Empty;
    var color = EffectiveBarColor(item);
    if (!string.IsNullOrEmpty(color)) style += $"fill: {color}; fill-opacity: 0.5;";
    if (IsEditable) style += "cursor: grab;";
    return style;
  }

  private string BuildProgressStyle(GanttItem item)
  {
    var color = EffectiveBarColor(item);
    return string.IsNullOrEmpty(color) ? string.Empty : $"fill: {color};";
  }

  private string BuildTextStyle(GanttItem item)
  {
    var color = EffectiveBarColor(item);
    if (string.IsNullOrEmpty(color)) color = DefaultBarBaseColor;
    return $"fill: {ComputeContrastColor(color)};";
  }

  // YIQ-based contrast color: dark text on light bg, white text on dark bg
  private static string ComputeContrastColor(string color)
  {
    if (!TryParseHexColor(color, out var r, out var g, out var b)) return "#1a1a1a";
    var y = (r * 299 + g * 587 + b * 114) / 1000;
    return y >= 128 ? "#1a1a1a" : "#ffffff";
  }

  private static bool TryParseHexColor(string color, out int r, out int g, out int b)
  {
    r = g = b = 0;
    if (string.IsNullOrEmpty(color) || color[0] != '#') return false;
    var hex = color.AsSpan(1);
    if (hex.Length == 3)
    {
      if (!byte.TryParse(hex.Slice(0, 1), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var rr)) return false;
      if (!byte.TryParse(hex.Slice(1, 1), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var gg)) return false;
      if (!byte.TryParse(hex.Slice(2, 1), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var bb)) return false;
      r = rr * 17; g = gg * 17; b = bb * 17;
      return true;
    }
    if (hex.Length == 6)
    {
      if (!byte.TryParse(hex.Slice(0, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var rr)) return false;
      if (!byte.TryParse(hex.Slice(2, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var gg)) return false;
      if (!byte.TryParse(hex.Slice(4, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var bb)) return false;
      r = rr; g = gg; b = bb;
      return true;
    }
    return false;
  }

  // ===== Layout calculation =====

  private record LayoutParams(List<DateTime> Dates, int HeaderHeight, double ColWidth, int RowHeight,
    int BodyHeight, int TotalHeight, double TimelineWidth, TimeSpan TimeUnit);

  private LayoutParams CalcLayout()
  {
    var dates = GetDates();
    var headerHeight = GetHeaderHeight();
    // FitToWidth で _containerWidth が未計測 (=0) のときは、SVG に intrinsic 幅を与えない。
    // 親が flex/grid の min-content を参照すると SVG の自然幅まで親が広がってしまい、
    // 計測値 (scroll.clientWidth) もその広がった値になって収束しないため。
    double colWidth = IsFitToWidth
      ? (_containerWidth > 0 && dates.Count > 0 ? (double)_containerWidth / dates.Count : 0)
      : GetDefaultColumnWidth();
    var bodyHeight = Math.Max(Field.Items.Count * RowHeight, RowHeight);
    var timeUnit = dates.Count >= 2 ? dates[1] - dates[0] : GetDefaultTimeUnit();
    double timelineWidth = IsFitToWidth
      ? (_containerWidth > 0 ? _containerWidth : 0)
      : dates.Count * colWidth;
    return new LayoutParams(dates, headerHeight, colWidth, RowHeight,
      bodyHeight, headerHeight + bodyHeight, timelineWidth, timeUnit);
  }

  private bool ShowDetailHeader => Field.Design.ShowDetailHeader;

  private int GetHeaderHeight()
  {
    if (Field.ViewMode == GanttViewMode.Day) return 28;
    if (!ShowDetailHeader) return 24;
    if (Field.IsDateOnly) return Field.ViewMode is GanttViewMode.Month or GanttViewMode.CustomRange ? 48 : 44;
    return Field.ViewMode switch
    {
      GanttViewMode.Month or GanttViewMode.CustomRange => 48,
      GanttViewMode.Week => 44,
      _ => 28,
    };
  }

  private int GetDefaultColumnWidth()
  {
    if (Field.IsDateOnly) return 32;
    return Field.ViewMode switch
    {
      GanttViewMode.Month or GanttViewMode.CustomRange => 32,
      GanttViewMode.Week => 14,
      _ => 40,
    };
  }

  private TimeSpan GetDefaultTimeUnit()
  {
    if (Field.IsDateOnly) return TimeSpan.FromDays(1);
    return Field.ViewMode switch
    {
      GanttViewMode.Month or GanttViewMode.CustomRange => TimeSpan.FromDays(1),
      GanttViewMode.Week => TimeSpan.FromHours(1),
      _ => TimeSpan.FromHours(1),
    };
  }

  // ===== SVG Render sections =====

  private RenderFragment RenderHeader(LayoutParams lp) => __builder =>
  {
    var useMonthDayHeader = Field.ViewMode is GanttViewMode.Month or GanttViewMode.CustomRange
                            || (Field.ViewMode == GanttViewMode.Week && Field.IsDateOnly);

    if (useMonthDayHeader)
    {
      RenderMonthGroupHeader(lp)(__builder);
      if (ShowDetailHeader)
      {
        var detailHeight = Field.ViewMode is GanttViewMode.Month or GanttViewMode.CustomRange ? 24 : 20;
        var textY = Field.ViewMode is GanttViewMode.Month or GanttViewMode.CustomRange ? 40 : 38;
        RenderDayDetailHeader(lp, detailHeight, textY)(__builder);
      }
    }
    else if (Field.ViewMode == GanttViewMode.Week)
    {
      RenderDayGroupHeader(lp)(__builder);
      if (ShowDetailHeader)
        RenderHourDetailHeader(lp)(__builder);
    }
    else
    {
      RenderDayViewHeader(lp)(__builder);
    }
    <line x1="0" y1="@lp.HeaderHeight" x2="@F(lp.TimelineWidth)" y2="@lp.HeaderHeight" class="gantt-header-sep" />
  };

  private RenderFragment RenderMonthGroupHeader(LayoutParams lp) => __builder =>
  {
    var mgX = 0.0;
    foreach (var mg in GetMonthGroups(lp.Dates))
    {
      var mgWidth = mg.Days * lp.ColWidth;
      <rect x="@F(mgX)" y="0" width="@F(mgWidth)" height="24" class="gantt-header-month-bg" />
      <g><text x="@F(mgX + mgWidth / 2)" y="16" class="gantt-header-month-text">@mg.Label</text></g>
      <line x1="@F(mgX)" y1="0" x2="@F(mgX)" y2="24" class="gantt-header-sep" />
      mgX += mgWidth;
    }
  };

  private RenderFragment RenderDayDetailHeader(LayoutParams lp, int detailHeight, int textY) => __builder =>
  {
    for (var i = 0; i < lp.Dates.Count; i++)
    {
      var x = i * lp.ColWidth;
      var d = lp.Dates[i];
      var isWeekend = d.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
      <rect x="@F(x)" y="24" width="@F(lp.ColWidth)" height="@detailHeight" class="@(isWeekend ? "gantt-header-weekend-bg" : "gantt-header-day-bg")" />
      <g><text x="@F(x + lp.ColWidth / 2)" y="@textY" class="gantt-header-day-text">@d.Day</text></g>
      <line x1="@F(x)" y1="24" x2="@F(x)" y2="@(24 + detailHeight)" class="gantt-header-sep-light" />
    }
    <line x1="0" y1="24" x2="@F(lp.TimelineWidth)" y2="24" class="gantt-header-sep" />
  };

  private RenderFragment RenderDayGroupHeader(LayoutParams lp) => __builder =>
  {
    var dgX = 0.0;
    foreach (var dg in GetDayGroups(lp.Dates))
    {
      var dgWidth = dg.Hours * lp.ColWidth;
      var isWeekend = dg.Date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
      <rect x="@F(dgX)" y="0" width="@F(dgWidth)" height="24" class="@(isWeekend ? "gantt-header-weekend-bg" : "gantt-header-day-bg")" />
      <g><text x="@F(dgX + dgWidth / 2)" y="16" class="gantt-header-date-text">@dg.Label</text></g>
      <line x1="@F(dgX)" y1="0" x2="@F(dgX)" y2="24" class="gantt-header-sep" />
      dgX += dgWidth;
    }
  };

  private RenderFragment RenderHourDetailHeader(LayoutParams lp) => __builder =>
  {
    for (var i = 0; i < lp.Dates.Count; i++)
    {
      var x = i * lp.ColWidth;
      var h = lp.Dates[i].Hour;
      if (h % 6 == 0)
      {
        <g><text x="@F(x + lp.ColWidth / 2)" y="@(lp.HeaderHeight - 4)" class="gantt-header-hour-text">@h</text></g>
      }
      <line x1="@F(x)" y1="24" x2="@F(x)" y2="@lp.HeaderHeight" class="gantt-header-sep-light" />
    }
    <line x1="0" y1="24" x2="@F(lp.TimelineWidth)" y2="24" class="gantt-header-sep" />
  };

  private RenderFragment RenderDayViewHeader(LayoutParams lp) => __builder =>
  {
    for (var i = 0; i < lp.Dates.Count; i++)
    {
      var x = i * lp.ColWidth;
      var h = lp.Dates[i].Hour;
      <rect x="@F(x)" y="0" width="@F(lp.ColWidth)" height="@lp.HeaderHeight"
            class="@(h >= 9 && h < 17 ? "gantt-header-day-bg" : "gantt-header-offhour-bg")" />
      <g><text x="@F(x + lp.ColWidth / 2)" y="@(lp.HeaderHeight - 6)" class="gantt-header-hour-text">@h</text></g>
      <line x1="@F(x)" y1="0" x2="@F(x)" y2="@lp.HeaderHeight" class="gantt-header-sep-light" />
    }
  };

  private RenderFragment RenderGrid(LayoutParams lp) => __builder =>
  {
    for (var i = 0; i < lp.Dates.Count; i++)
    {
      var x = i * lp.ColWidth;
      var d = lp.Dates[i];
      var isWeekend = (Field.ViewMode is GanttViewMode.Month or GanttViewMode.CustomRange || Field.IsDateOnly)
        && d.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
      if (isWeekend)
      {
        <rect x="@F(x)" y="@lp.HeaderHeight" width="@F(lp.ColWidth)" height="@lp.BodyHeight" class="gantt-grid-weekend" />
      }
      if (i > 0)
      {
        <line x1="@F(x)" y1="@lp.HeaderHeight" x2="@F(x)" y2="@lp.TotalHeight"
              class="@(IsMainGridLine(d) ? "gantt-grid-line-main" : "gantt-grid-line")" />
      }
    }
    for (var r = 0; r <= Field.Items.Count; r++)
    {
      var y = lp.HeaderHeight + r * lp.RowHeight;
      <line x1="0" y1="@y" x2="@F(lp.TimelineWidth)" y2="@y" class="gantt-grid-row-line" />
    }
  };

  private RenderFragment RenderTodayLine(LayoutParams lp) => __builder =>
  {
    var todayX = GetTodayX(lp);
    if (todayX >= 0 && todayX <= lp.TimelineWidth)
    {
      <line x1="@todayX" y1="@lp.HeaderHeight" x2="@todayX" y2="@lp.TotalHeight" class="gantt-today-line" />
      <polygon points="@TodayMarker(todayX, lp.HeaderHeight)" class="gantt-today-marker" />
    }
  };

  private RenderFragment RenderTaskBars(LayoutParams lp) => __builder =>
  {
    for (var idx = 0; idx < Field.Items.Count; idx++)
    {
      var item = Field.Items[idx];
      var bar = GetBarPosition(item, lp, idx);
      if (bar.Width <= 0) continue;

      var capturedItem = item;
      var capturedIdx = idx;

      <rect x="@bar.X" y="@bar.Y" width="@bar.Width" height="@bar.Height"
            rx="4" ry="4" class="gantt-task-bar"
            style="@BuildBarStyle(item)"
            @onmousedown="e => OnBarMouseDown(e, capturedIdx, capturedItem)"
            @onmousedown:preventDefault="true"
            @onmousedown:stopPropagation="true"
            @oncontextmenu="e => OnBarContextMenu(e, capturedItem)"
            @oncontextmenu:preventDefault="true"
            @oncontextmenu:stopPropagation="true" />

      @if (item.Progress > 0)
      {
        var progressWidth = bar.Width * item.Progress / 100.0;
        <rect x="@bar.X" y="@bar.Y" width="@progressWidth" height="@bar.Height"
              rx="4" ry="4" class="gantt-task-progress" style="@BuildProgressStyle(item)" />
        if (progressWidth < bar.Width)
        {
          <rect x="@(bar.X + progressWidth - 4)" y="@bar.Y" width="4" height="@bar.Height"
                class="gantt-task-progress" style="@BuildProgressStyle(item)" />
        }
      }

      <g><text x="@(bar.X + 8)" y="@(bar.Y + bar.Height / 2 + 4)"
            class="gantt-task-text" style="@BuildTextStyle(item)" pointer-events="none">@TruncateText(item.Text, bar.Width)</text></g>

      @if (IsEditable && bar.Width >= 20)
      {
        var handleW = Math.Max(4, Math.Min(6, bar.Width * 0.2));
        <rect x="@F(bar.X)" y="@bar.Y" width="@F(handleW)" height="@bar.Height"
              class="gantt-resize-handle" rx="2" ry="2"
              @onmousedown="e => StartDrag(e, capturedIdx, DragMode.ResizeLeft)"
              @onmousedown:preventDefault="true"
              @onmousedown:stopPropagation="true" />
        <rect x="@F(bar.X + bar.Width - handleW)" y="@bar.Y" width="@F(handleW)" height="@bar.Height"
              class="gantt-resize-handle" rx="2" ry="2"
              @onmousedown="e => StartDrag(e, capturedIdx, DragMode.ResizeRight)"
              @onmousedown:preventDefault="true"
              @onmousedown:stopPropagation="true" />
      }

      @if (_depLinkingSourceId == item.Id)
      {
        var stubX1 = bar.X + bar.Width;
        var stubY = bar.Y + bar.Height / 2;
        var stubX2 = stubX1 + 30;
        <line x1="@F(stubX1)" y1="@F(stubY)" x2="@F(stubX2)" y2="@F(stubY)"
              class="gantt-dep-linking-stub" pointer-events="none" />
        <circle cx="@F(stubX2)" cy="@F(stubY)" r="3" class="gantt-dep-linking-dot" />
      }
    }
  };

  private RenderFragment RenderDependencyArrows(LayoutParams lp) => __builder =>
  {
    var itemIndexMap = new Dictionary<string, int>();
    for (var i = 0; i < Field.Items.Count; i++)
      itemIndexMap[Field.Items[i].Id] = i;

    foreach (var dep in Field.DependencyList)
    {
      if (!itemIndexMap.TryGetValue(dep.From, out var fromIdx) ||
          !itemIndexMap.TryGetValue(dep.To, out var toIdx)) continue;

      var fromBar = GetBarPosition(Field.Items[fromIdx], lp, fromIdx);
      var toBar = GetBarPosition(Field.Items[toIdx], lp, toIdx);
      if (fromBar.Width <= 0 || toBar.Width <= 0) continue;

      var x1 = fromBar.X + fromBar.Width;
      var y1 = fromBar.Y + fromBar.Height / 2;
      var x2 = toBar.X;
      var y2 = toBar.Y + toBar.Height / 2;
      var midX = x1 + 12;
      var isSelected = _selectedDepKey == dep.Key;
      var capturedKey = dep.Key;
      var pathD = $"M {F(x1)},{F(y1)} L {F(midX)},{F(y1)} L {F(midX)},{F(y2)} L {F(x2)},{F(y2)}";

      <path d="@pathD" class="gantt-dep-hit-area"
            style="@(IsEditable ? "" : "cursor: default;")"
            @onclick="() => OnDepLineClick(capturedKey)"
            @onclick:stopPropagation="true" />
      <path d="@pathD"
            class="@(isSelected ? "gantt-dep-line gantt-dep-selected" : "gantt-dep-line")"
            marker-end="@(isSelected ? "url(#dep-arrow-selected)" : "url(#dep-arrow)")"
            pointer-events="none" />
    }
  };

  // ===== Navigation =====

  private string GetTitle()
  {
    var (start, end) = Field.GetViewDateRange();
    var s = start;
    var e = end.AddDays(-1);
    if (Field.ViewMode == GanttViewMode.CustomRange)
    {
      return string.Format(Resources.RangeTitleFormat,
        s.ToString(Resources.DateFormatDateShort, _culture),
        e.ToString(Resources.DateFormatDateShort, _culture));
    }
    return Field.ViewMode switch
    {
      GanttViewMode.Day => s.ToString(Resources.DateFormatMonthDayShort, _culture),
      GanttViewMode.Month when s.Month == e.Month => s.ToString(Resources.DateFormatMonthNameFull, _culture),
      GanttViewMode.Month => string.Format(Resources.RangeTitleFormat,
        s.ToString(Resources.DateFormatMonthNameShort, _culture),
        e.ToString(Resources.DateFormatMonthNameFull, _culture)),
      _ when s.Month == e.Month => string.Format(Resources.WeekTitleSameMonth,
        s.ToString(Resources.DateFormatMonthNameFull, _culture), s.Day, e.Day, ""),
      _ => string.Format(Resources.RangeTitleFormat,
        s.ToString(Resources.DateFormatMonthDayShort, _culture),
        e.ToString(Resources.DateFormatMonthDayShort, _culture)),
    };
  }

  private async Task GoToday()
  {
    var start = Field.ViewMode switch
    {
      GanttViewMode.Day => DateTime.Today,
      GanttViewMode.Month => new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
      _ => DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek),
    };
    await Field.SetViewStartAsync(start);
  }

  private async Task GoPrev()
  {
    var next = Field.ViewMode switch
    {
      GanttViewMode.Day => Field.ViewStart.AddDays(-1),
      GanttViewMode.Month => Field.ViewStart.AddMonths(-1),
      _ => Field.ViewStart.AddDays(-7),
    };
    await Field.SetViewStartAsync(next);
  }

  private async Task GoNext()
  {
    var next = Field.ViewMode switch
    {
      GanttViewMode.Day => Field.ViewStart.AddDays(1),
      GanttViewMode.Month => Field.ViewStart.AddMonths(1),
      _ => Field.ViewStart.AddDays(7),
    };
    await Field.SetViewStartAsync(next);
  }

  private async Task SetViewMode(GanttViewMode mode)
  {
    var newStart = mode switch
    {
      GanttViewMode.Day => DateTime.Today,
      GanttViewMode.Month => new DateTime(Field.ViewStart.Year, Field.ViewStart.Month, 1),
      _ => Field.ViewStart.Date.AddDays(-(int)Field.ViewStart.DayOfWeek),
    };
    await Field.SetViewModeAsync(mode);
    await Field.SetViewStartAsync(newStart);
  }

  bool _rangePopupOpen;
  DateTime _rangeEditStart;
  DateTime _rangeEditEnd;

  private void OpenRangePopup()
  {
    _rangeEditStart = Field.CustomRangeStart;
    _rangeEditEnd = Field.CustomRangeEnd;
    _rangePopupOpen = true;
  }

  private void CloseRangePopup() => _rangePopupOpen = false;

  private async Task ApplyRangePopup()
  {
    if (_rangeEditStart >= _rangeEditEnd) return;
    _rangePopupOpen = false;
    await Field.SetCustomRangeAsync(_rangeEditStart, _rangeEditEnd);
  }

  // ===== Event handlers =====

  private async Task OnAddClicked()
  {
    if (!IsEditable) return;
    await Field.AddAsync(DateTime.Now);
  }

  private async Task OnTaskClicked(GanttItem item)
    => await Field.EditAsync(item.Module, !IsEditable);

  private void OnContainerClick()
  {
    _selectedDepKey = null;
    _depLinkingSourceId = null;
  }

  private async Task OnBarMouseDown(MouseEventArgs e, int idx, GanttItem item)
  {
    if (!IsEditable) return;
    if (_depLinkingSourceId != null)
    {
      if (item.Id != _depLinkingSourceId)
      {
        var sourceId = _depLinkingSourceId;
        _depLinkingSourceId = null;
        await Field.AddDependenciesAsync(sourceId, item.Id);
      }
      return;
    }
    _selectedDepKey = null;
    if (e.Button == 0) StartDrag(e, idx, DragMode.Move);
  }

  private void OnBarContextMenu(MouseEventArgs e, GanttItem item)
  {
    if (!IsEditable || _depLinkingSourceId != null) return;
    _contextMenuVisible = true;
    _contextMenuX = e.ClientX;
    _contextMenuY = e.ClientY;
    _contextMenuTaskId = item.Id;
    _selectedDepKey = null;
  }

  private void CloseContextMenu()
  {
    _contextMenuVisible = false;
    _contextMenuTaskId = null;
  }

  private void OnContextMenuAddDep()
  {
    _depLinkingSourceId = _contextMenuTaskId;
    _contextMenuVisible = false;
    _contextMenuTaskId = null;
  }

  private void OnDepLineClick(string key)
  {
    if (!IsEditable) return;
    _selectedDepKey = _selectedDepKey == key ? null : key;
    _depLinkingSourceId = null;
    StateHasChanged();
  }

  private async Task OnKeyDown(KeyboardEventArgs e)
  {
    if (!IsEditable) return;
    if (e.Key == "Delete" && _selectedDepKey != null)
    {
      var dep = Field.DependencyList.FirstOrDefault(x => x.Key == _selectedDepKey);
      if (dep != null)
      {
        _selectedDepKey = null;
        await Field.DeleteDependenciesAsync(dep.From, dep.To);
      }
    }
    else if (e.Key == "Escape")
    {
      _depLinkingSourceId = null;
      _selectedDepKey = null;
      StateHasChanged();
    }
  }

  // ===== Date generation =====

  private int GetMaxColumns()
  {
    if (!IsFitToWidth || _containerWidth <= 0) return int.MaxValue;
    var minColWidth = GetDefaultColumnWidth();
    return Math.Max(1, _containerWidth / minColWidth);
  }

  private List<DateTime> GetDates()
  {
    var (start, end) = Field.GetViewDateRange();
    var maxCols = GetMaxColumns();

    if (Field.IsDateOnly)
      return GenerateDateList(start, end, maxCols, [1, 2, 7, 14], s => TimeSpan.FromDays(s));

    return Field.ViewMode switch
    {
      GanttViewMode.Day => GenerateDateList(start.Date, start.Date.AddDays(1), maxCols,
        [1, 2, 3, 6, 12], s => TimeSpan.FromHours(s)),
      GanttViewMode.Week => GenerateDateList(start, end, maxCols,
        [1, 2, 3, 6, 12, 24], s => TimeSpan.FromHours(s)),
      GanttViewMode.CustomRange => GenerateDateList(start.Date, end, maxCols,
        [1, 2, 7, 14, 28], s => TimeSpan.FromDays(s)),
      _ => GenerateDateList(start.Date, end, maxCols,
        [1, 2, 7, 14], s => TimeSpan.FromDays(s)),
    };
  }

  private static List<DateTime> GenerateDateList(DateTime start, DateTime end, int maxCols,
    int[] steps, Func<int, TimeSpan> toSpan)
  {
    var totalRange = end - start;
    var step = toSpan(steps[0]);
    foreach (var s in steps)
    {
      step = toSpan(s);
      var count = (int)(totalRange / step);
      if (count <= maxCols) break;
    }

    var list = new List<DateTime>();
    for (var c = start; c < end; c += step)
      list.Add(c);
    return list;
  }

  // ===== Header helpers =====

  private record MonthGroup(string Label, int Days);
  private record DayGroup(string Label, DateTime Date, int Hours);

  private List<MonthGroup> GetMonthGroups(List<DateTime> dates)
  {
    var groups = new List<MonthGroup>();
    if (dates.Count == 0) return groups;
    var curMonth = dates[0].Month;
    var curYear = dates[0].Year;
    var count = 0;
    foreach (var d in dates)
    {
      if (d.Month != curMonth || d.Year != curYear)
      {
        groups.Add(new MonthGroup(new DateTime(curYear, curMonth, 1).ToString(Resources.DateFormatMonthNameFull, _culture), count));
        curMonth = d.Month;
        curYear = d.Year;
        count = 0;
      }
      count++;
    }
    if (count > 0)
      groups.Add(new MonthGroup(new DateTime(curYear, curMonth, 1).ToString(Resources.DateFormatMonthNameFull, _culture), count));
    return groups;
  }

  private List<DayGroup> GetDayGroups(List<DateTime> dates)
  {
    var groups = new List<DayGroup>();
    if (dates.Count == 0) return groups;
    var curDate = dates[0].Date;
    var count = 0;
    foreach (var d in dates)
    {
      if (d.Date != curDate)
      {
        groups.Add(new DayGroup(curDate.ToString(Resources.DateFormatDayGroupShort, _culture), curDate, count));
        curDate = d.Date;
        count = 0;
      }
      count++;
    }
    if (count > 0)
      groups.Add(new DayGroup(curDate.ToString(Resources.DateFormatDayGroupShort, _culture), curDate, count));
    return groups;
  }

  private bool IsMainGridLine(DateTime d)
  {
    if (Field.IsDateOnly) return d.DayOfWeek == DayOfWeek.Monday;
    return Field.ViewMode switch
    {
      GanttViewMode.Month or GanttViewMode.CustomRange => d.DayOfWeek == DayOfWeek.Monday,
      GanttViewMode.Week => d.Hour == 0,
      _ => d.Hour % 6 == 0,
    };
  }

  // ===== Positioning =====

  private double GetTodayX(LayoutParams lp)
  {
    if (lp.Dates.Count == 0) return -1;
    var now = DateTime.Now;
    var start = lp.Dates[0];
    var endDate = lp.Dates[^1].Add(lp.TimeUnit);
    if (now < start || now > endDate) return -1;
    var totalUnits = (endDate - start).TotalSeconds / lp.TimeUnit.TotalSeconds;
    var nowUnits = (now - start).TotalSeconds / lp.TimeUnit.TotalSeconds;
    return nowUnits / totalUnits * lp.TimelineWidth;
  }

  private string TodayMarker(double x, int headerHeight)
    => $"{F(x - 5)},{headerHeight} {F(x + 5)},{headerHeight} {F(x)},{headerHeight + 6}";

  private record BarPosition(double X, double Y, double Width, double Height);

  private BarPosition GetBarPosition(GanttItem item, LayoutParams lp, int rowIdx)
  {
    if (lp.Dates.Count == 0) return new(0, 0, 0, 0);

    var start = lp.Dates[0];
    var endDate = lp.Dates[^1].Add(lp.TimeUnit);
    var totalUnits = (endDate - start).TotalSeconds / lp.TimeUnit.TotalSeconds;

    var barStart = Math.Max(0, (item.Start - start).TotalSeconds / lp.TimeUnit.TotalSeconds);
    var barEnd = Math.Min(totalUnits, (item.End - start).TotalSeconds / lp.TimeUnit.TotalSeconds);
    if (barEnd <= barStart) return new(0, 0, 0, 0);

    var pxPerUnit = (double)lp.TimelineWidth / totalUnits;
    return new(
      barStart * pxPerUnit,
      lp.HeaderHeight + rowIdx * lp.RowHeight + BarPadding,
      Math.Max((barEnd - barStart) * pxPerUnit, 4),
      lp.RowHeight - BarPadding * 2);
  }

  private static string TruncateText(string text, double width)
  {
    var maxChars = (int)(width / 7) - 1;
    if (maxChars <= 0) return "";
    if (text.Length <= maxChars) return text;
    return maxChars <= 3 ? "" : text[..(maxChars - 1)] + "...";
  }

  // ===== Drag & Drop =====

  private TimeSpan GetDragSnapUnit()
  {
    if (Field.IsDateOnly) return TimeSpan.FromDays(1);
    return Field.ViewMode switch
    {
      GanttViewMode.Month or GanttViewMode.CustomRange => TimeSpan.FromHours(12),
      GanttViewMode.Week => TimeSpan.FromHours(1),
      _ => TimeSpan.FromMinutes(15),
    };
  }

  private double _dragPxPerSecond;

  private void StartDrag(MouseEventArgs e, int idx, DragMode mode)
  {
    if (!IsEditable || _depLinkingSourceId != null) return;
    _dragging = true;
    _dragIdx = idx;
    _dragMode = mode;
    _dragStartX = e.ClientX;
    _dragOrigStart = Field.Items[idx].Start;
    _dragOrigEnd = Field.Items[idx].End;

    var lp = CalcLayout();
    var (rangeStart, rangeEnd) = Field.GetViewDateRange();
    var totalSeconds = (rangeEnd - rangeStart).TotalSeconds;
    _dragPxPerSecond = totalSeconds > 0 ? lp.TimelineWidth / totalSeconds : 1;
  }

  private void OnMouseMove(MouseEventArgs e)
  {
    if (!_dragging || _dragIdx < 0 || _dragIdx >= Field.Items.Count) return;

    var snap = GetDragSnapUnit();
    var deltaPx = e.ClientX - _dragStartX;
    var deltaSeconds = deltaPx / _dragPxPerSecond;
    var steps = (long)Math.Round(deltaSeconds / snap.TotalSeconds);
    var delta = TimeSpan.FromTicks(snap.Ticks * steps);
    var item = Field.Items[_dragIdx];

    switch (_dragMode)
    {
      case DragMode.Move:
        item.Start = _dragOrigStart + delta;
        item.End = _dragOrigEnd + delta;
        break;
      case DragMode.ResizeLeft:
        var newStart = _dragOrigStart + delta;
        if (newStart < _dragOrigEnd) item.Start = newStart;
        break;
      case DragMode.ResizeRight:
        var newEnd = _dragOrigEnd + delta;
        if (newEnd > _dragOrigStart) item.End = newEnd;
        break;
    }
    StateHasChanged();
  }

  private async Task OnMouseUp(MouseEventArgs e)
  {
    if (!_dragging) return;
    _dragging = false;
    if (_dragIdx < 0 || _dragIdx >= Field.Items.Count) return;

    var item = Field.Items[_dragIdx];
    if (item.Start != _dragOrigStart || item.End != _dragOrigEnd)
      await Field.UpdateTaskDatesAsync(item, item.Start, item.End);
  }

}
