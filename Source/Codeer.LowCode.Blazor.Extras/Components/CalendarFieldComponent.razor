@using System.Globalization
@using Microsoft.AspNetCore.Components.Web
@using Codeer.LowCode.Blazor.Components
@using Codeer.LowCode.Blazor.Extras.Fields
@using Codeer.LowCode.Blazor.Extras.Properties
@inherits FieldComponentBase<CalendarField>

<div @ref="Element" class="calendar-container">
  @* ===== Toolbar ===== *@
  <div class="calendar-toolbar">
    <div class="toolbar-left">
      <button type="button" class="toolbar-btn toolbar-btn-today" @onclick="GoToday">@Resources.Today</button>
      <button type="button" class="toolbar-btn toolbar-btn-prev" @onclick="GoPrev">&#9664;</button>
      <button type="button" class="toolbar-btn toolbar-btn-next" @onclick="GoNext">&#9654;</button>
      <span class="toolbar-title">@GetTitle()</span>
    </div>
    @if (EnabledViewModeCount > 1)
    {
      <div class="toolbar-right">
        <div class="view-switcher">
          @if (Field.IsViewModeEnabled(CalendarViewMode.Day))
          {
            <button type="button" class="view-btn @(Field.ViewMode == CalendarViewMode.Day ? "active" : "")"
                    @onclick="() => SetViewMode(CalendarViewMode.Day)">@Resources.Day</button>
          }
          @if (Field.IsViewModeEnabled(CalendarViewMode.Week))
          {
            <button type="button" class="view-btn @(Field.ViewMode == CalendarViewMode.Week ? "active" : "")"
                    @onclick="() => SetViewMode(CalendarViewMode.Week)">@Resources.Week</button>
          }
          @if (Field.IsViewModeEnabled(CalendarViewMode.Month))
          {
            <button type="button" class="view-btn @(Field.ViewMode == CalendarViewMode.Month ? "active" : "")"
                    @onclick="() => SetViewMode(CalendarViewMode.Month)">@Resources.Month</button>
          }
        </div>
      </div>
    }
  </div>

  @* ===== Month View ===== *@
  @if (Field.ViewMode == CalendarViewMode.Month)
  {
    var weeks = GetMonthWeeks();
    PrepareBuckets(weeks[0][0].Date, weeks.Count * 7);
    <div class="month-view">
      <div class="month-grid">
        <div class="month-header">
          @foreach (var d in DayNames)
          {
            <div class="month-header-cell">@d</div>
          }
        </div>
        @foreach (var week in weeks)
        {
          <div class="month-row">
            @foreach (var day in week)
            {
              <div class="month-cell @(day.IsCurrentMonth ? "" : "month-cell-other-month") @(day.IsToday ? "month-cell-today" : "")"
                   style="@(IsEditable ? "" : "cursor: default;")"
                   @onclick="() => OnCellClicked(day.Date)">
                <div class="month-date @(day.IsToday ? "month-date-today" : "")">@day.Date.Day</div>
                @foreach (var evt in GetMonthDayEvents(day.Date))
                {
                  @RenderMonthEvent(evt, day.Date)
                }
              </div>
            }
          </div>
        }
      </div>
    </div>
  }

  @* ===== Week View ===== *@
  @if (Field.ViewMode == CalendarViewMode.Week)
  {
    var weekDays = GetWeekDays();
    PrepareBuckets(weekDays[0].Date, 7);
    var weekAllDay = weekDays.Select(d => GetAllDayEventsForDay(d.Date)).ToList();
    <div class="week-view">
      <div class="time-grid-scroll">
        <div class="week-header">
          <div class="time-gutter-header"></div>
          @foreach (var d in weekDays)
          {
            <div class="week-header-cell @(d.IsToday ? "week-header-cell-today" : "")">
              <div class="week-header-dayname">@DayNames[(int)d.Date.DayOfWeek]</div>
              <div class="week-header-date @(d.IsToday ? "week-header-date-today" : "")">@d.Date.Day</div>
            </div>
          }
        </div>
        @if (weekAllDay.Any(g => g.Count > 0))
        {
          <div class="allday-section">
            <div class="time-gutter allday-gutter"></div>
            @foreach (var dayEvts in weekAllDay)
            {
              <div class="allday-cell">
                @foreach (var evt in dayEvts)
                {
                  @RenderAllDayEvent(evt)
                }
              </div>
            }
          </div>
        }
        <div class="time-grid">
          @RenderTimeGutter()
          @foreach (var d in weekDays)
          {
            @RenderTimeColumn(d.Date, d.IsToday)
          }
        </div>
      </div>
    </div>
  }

  @* ===== Day View ===== *@
  @if (Field.ViewMode == CalendarViewMode.Day)
  {
    var dayDate = Field.SelectedDate.Date;
    PrepareBuckets(dayDate, 1);
    var dayAllDay = GetAllDayEventsForDay(dayDate);
    <div class="day-view">
      <div class="day-header">
        <div class="time-gutter-header"></div>
        <div class="day-header-cell">
          <span class="day-header-dayname">@dayDate.ToString(Resources.DateFormatDayName, CultureInfo.CurrentUICulture)</span>
          <span class="day-header-date @(dayDate == DateTime.Today ? "day-header-date-today" : "")">@dayDate.Day</span>
        </div>
      </div>
      <div class="time-grid-scroll">
        @if (dayAllDay.Count > 0)
        {
          <div class="allday-section">
            <div class="time-gutter allday-gutter"></div>
            <div class="allday-cell day-allday-cell">
              @foreach (var evt in dayAllDay)
              {
                @RenderAllDayEvent(evt)
              }
            </div>
          </div>
        }
        <div class="time-grid day-time-grid">
          @RenderTimeGutter()
          @RenderTimeColumn(dayDate, true)
        </div>
      </div>
    </div>
  }
</div>

@code {
  const double PxPerHour = 48.0;
  const double MinEventHeight = 20.0;

  // 表示範囲のイベントを日付キーで振り分けたバケット。描画の頭で1回だけ構築する。
  // (従来は各セルで Field.Items 全件をスキャンしており O(セル数 × N) だった)
  private readonly Dictionary<DateTime, List<ModuleCalendarItem>> _dayBuckets = new();

  private void PrepareBuckets(DateTime start, int days)
  {
    _dayBuckets.Clear();
    var rangeStart = start.Date;
    var rangeEnd = rangeStart.AddDays(days); // exclusive
    for (var i = 0; i < days; i++)
      _dayBuckets[rangeStart.AddDays(i)] = new List<ModuleCalendarItem>();

    foreach (var item in Field.Items)
    {
      if (item.Start == default) continue;
      var s = item.Start.Date;
      var e = (item.End ?? item.Start).Date;
      if (e < rangeStart || s >= rangeEnd) continue;
      var from = s < rangeStart ? rangeStart : s;
      var to = e >= rangeEnd ? rangeEnd.AddDays(-1) : e;
      for (var d = from; d <= to; d = d.AddDays(1))
        if (_dayBuckets.TryGetValue(d, out var list))
          list.Add(item);
    }

    // 各日: 終日/複数日を先頭、その後は開始時刻順。月表示のクリップ表示や整列に効く。
    foreach (var list in _dayBuckets.Values)
    {
      if (list.Count > 1)
        list.Sort((a, b) =>
        {
          if (a.AllDay != b.AllDay) return a.AllDay ? -1 : 1;
          return a.Start.CompareTo(b.Start);
        });
    }
  }

  private List<ModuleCalendarItem> DayBucket(DateTime date)
    => _dayBuckets.TryGetValue(date.Date, out var l) ? l : [];

  // カルチャ単位でキャッシュ (getのたびの配列生成を避ける)
  private string[]? _dayNames;
  private string? _dayNamesCulture;
  private string[] DayNames
  {
    get
    {
      var cn = CultureInfo.CurrentUICulture.Name;
      if (_dayNames is null || _dayNamesCulture != cn)
      {
        _dayNames = [Resources.Sun, Resources.Mon, Resources.Tue, Resources.Wed, Resources.Thu, Resources.Fri, Resources.Sat];
        _dayNamesCulture = cn;
      }
      return _dayNames;
    }
  }

  private CultureInfo Culture => CultureInfo.CurrentUICulture;

  private string Px(double v) => v.ToString("0.#", CultureInfo.InvariantCulture) + "px";

  private int EnabledViewModeCount =>
    (Field.IsViewModeEnabled(CalendarViewMode.Day) ? 1 : 0) +
    (Field.IsViewModeEnabled(CalendarViewMode.Week) ? 1 : 0) +
    (Field.IsViewModeEnabled(CalendarViewMode.Month) ? 1 : 0);

  private string EventColorStyle(ModuleCalendarItem item)
    => string.IsNullOrEmpty(item.Color) ? "" : $"background:{item.Color};";

  // ===== Shared render methods =====

  private RenderFragment RenderMonthEvent(ModuleCalendarItem evt, DateTime cellDate) => __builder =>
  {
    var isMultiDay = !evt.AllDay && evt.End.HasValue && evt.Start.Date != evt.End.Value.Date;
    var isStartDay = cellDate == evt.Start.Date;
    var isEndDay = evt.End.HasValue && cellDate == evt.End.Value.Date;
    var eventClass = evt.AllDay || isMultiDay ? "month-event-allday" : "month-event-timed";
    <div class="month-event @eventClass"
         style="@EventColorStyle(evt)"
         @onclick="() => OnEventClicked(evt)" @onclick:stopPropagation="true"
         title="@GetEventTooltip(evt)">
      @if (!evt.AllDay && !isMultiDay)
      {
        <span class="month-event-dot"></span>
        @if (!evt.IsDateOnly)
        {
          <span class="month-event-time">@evt.Start.ToString("H:mm")</span>
        }
      }
      else if (!evt.IsDateOnly)
      {
        @if (isMultiDay && isStartDay)
        {
          <span class="month-event-time">@evt.Start.ToString("H:mm") -</span>
        }
        else if (isMultiDay && isEndDay)
        {
          <span class="month-event-time">- @evt.End!.Value.ToString("H:mm")</span>
        }
      }
      <span class="month-event-text">@evt.Text</span>
    </div>
  };

  private RenderFragment RenderAllDayEvent(ModuleCalendarItem evt) => __builder =>
  {
    <div class="allday-event" style="@EventColorStyle(evt)" @onclick="() => OnEventClicked(evt)" title="@evt.Text">
      @evt.Text
    </div>
  };

  private RenderFragment RenderTimeGutter() => __builder =>
  {
    <div class="time-gutter">
      @for (var h = 0; h < 24; h++)
      {
        <div class="time-gutter-cell">
          <span class="time-label">@(h == 0 ? "" : $"{h}:00")</span>
        </div>
      }
    </div>
  };

  private RenderFragment RenderTimeColumn(DateTime date, bool isToday) => __builder =>
  {
    var dayEvents = GetTimedEventsForDay(date);
    <div class="time-column @(isToday ? "time-column-today" : "")" style="@(IsEditable ? "" : "cursor: default;")" @onclick="() => OnCellClicked(date)">
      @for (var h = 0; h < 24; h++)
      {
        <div class="time-cell"></div>
      }
      @foreach (var pos in dayEvents)
      {
        var layerOffset = pos.Layer * 14;
        var timeText = GetTimeEventTimeText(pos);
        <div class="time-event"
             style="top: @Px(pos.TopPx); left: @Px(layerOffset); width: calc(100% - @Px(layerOffset) - 2px); height: @Px(pos.HeightPx); z-index: @(pos.Layer + 1); @EventColorStyle(pos.Item)"
             @onclick="() => OnEventClicked(pos.Item)" @onclick:stopPropagation="true"
             title="@GetEventTooltip(pos.Item)">
          <div class="time-event-title">@pos.Item.Text</div>
          @if (!string.IsNullOrEmpty(timeText))
          {
            <div class="time-event-time">@timeText</div>
          }
        </div>
      }
    </div>
  };

  // ===== Navigation =====

  private string GetTitle() => Field.ViewMode switch
  {
    CalendarViewMode.Day => Field.SelectedDate.ToString(Resources.DateFormatDayTitle, Culture),
    CalendarViewMode.Week => GetWeekTitle(),
    _ => Field.SelectedDate.ToString(Resources.DateFormatMonthTitle, Culture),
  };

  private string GetWeekTitle()
  {
    var start = Field.SelectedDate.Date.AddDays(-(int)Field.SelectedDate.DayOfWeek);
    var end = start.AddDays(6);
    if (start.Month == end.Month)
      return string.Format(Resources.WeekTitleSameMonth,
        start.ToString(Resources.DateFormatMonthNameFull, Culture), start.Day, end.Day, start.Year);
    if (start.Year == end.Year)
      return string.Format(Resources.WeekTitleDiffMonth,
        start.ToString(Resources.DateFormatMonthNameShort, Culture), start.Day,
        end.ToString(Resources.DateFormatMonthNameShort, Culture), end.Day, start.Year);
    return string.Format(Resources.RangeTitleFormat,
      start.ToString(Resources.DateFormatDateShort, Culture),
      end.ToString(Resources.DateFormatDateShort, Culture));
  }

  private async Task GoToday() => await Field.SetCurrentDayAsync(DateTime.Now);

  private async Task GoPrev()
  {
    var d = Field.SelectedDate;
    var next = Field.ViewMode switch
    {
      CalendarViewMode.Day => d.AddDays(-1),
      CalendarViewMode.Week => d.AddDays(-7),
      _ => d.AddMonths(-1),
    };
    await Field.SetCurrentDayAsync(next);
  }

  private async Task GoNext()
  {
    var d = Field.SelectedDate;
    var next = Field.ViewMode switch
    {
      CalendarViewMode.Day => d.AddDays(1),
      CalendarViewMode.Week => d.AddDays(7),
      _ => d.AddMonths(1),
    };
    await Field.SetCurrentDayAsync(next);
  }

  private async Task SetViewMode(CalendarViewMode mode) => await Field.SetViewModeAsync(mode);

  // ===== ViewOnly / Enabled =====
  private bool IsDisabled => Field.IsEnabled == false;
  private bool IsViewMode => Field.IsViewOnly;
  private bool IsEditable => !IsViewMode && !IsDisabled;

  // ===== Event handlers =====

  private async Task OnCellClicked(DateTime date)
  {
    if (!IsEditable) return;
    await Field.AddAsync(date);
  }

  private async Task OnEventClicked(ModuleCalendarItem item)
  {
    await Field.EditAsync(item.Module, !IsEditable);
  }

  // ===== Month View helpers =====

  private List<List<CalendarDay>> GetMonthWeeks()
  {
    var selected = Field.SelectedDate;
    var year = selected.Year;
    var month = selected.Month;
    var firstDay = new DateTime(year, month, 1);
    var startDate = firstDay.AddDays(-(int)firstDay.DayOfWeek);
    var today = DateTime.Today;
    var weeks = new List<List<CalendarDay>>();

    for (var w = 0; w < 6; w++)
    {
      var week = new List<CalendarDay>(7);
      for (var d = 0; d < 7; d++)
      {
        var date = startDate.AddDays(w * 7 + d);
        week.Add(new CalendarDay(date, date.Year == year && date.Month == month, date.Date == today));
      }
      weeks.Add(week);
    }
    return weeks;
  }

  private List<ModuleCalendarItem> GetMonthDayEvents(DateTime date) => DayBucket(date);

  // ===== Week View helpers =====

  private List<CalendarDay> GetWeekDays()
  {
    var start = Field.SelectedDate.Date.AddDays(-(int)Field.SelectedDate.DayOfWeek);
    var today = DateTime.Today;
    return Enumerable.Range(0, 7)
      .Select(i => { var date = start.AddDays(i); return new CalendarDay(date, true, date.Date == today); })
      .ToList();
  }

  private List<ModuleCalendarItem> GetAllDayEventsForDay(DateTime date)
    => DayBucket(date).Where(item => item.AllDay).ToList();

  // ===== Time grid event positioning =====

  private List<EventPosition> GetTimedEventsForDay(DateTime date)
  {
    var dayStart = date.Date;
    var dayEnd = dayStart.AddDays(1);

    var clipped = DayBucket(date)
      .Where(item => !item.AllDay && item.Start < dayEnd && (item.End ?? item.Start) > dayStart)
      .Select(item =>
      {
        var s = item.Start < dayStart ? dayStart : item.Start;
        var e = (item.End ?? item.Start) > dayEnd ? dayEnd : (item.End ?? item.Start);
        if (e <= s) e = s.AddMinutes(30);
        return (Item: item, Start: s, End: e);
      })
      .OrderBy(e => e.Start)
      .ThenByDescending(e => e.End - e.Start)
      .ToList();

    if (clipped.Count == 0) return [];

    var layers = AssignLayers(clipped);

    return clipped.Select((e, i) =>
    {
      var isMultiDay = e.Item.End.HasValue && e.Item.Start.Date != e.Item.End.Value.Date;
      return new EventPosition
      {
        Item = e.Item,
        Layer = layers[i],
        TopPx = (e.Start - dayStart).TotalHours * PxPerHour,
        HeightPx = Math.Max((e.End - e.Start).TotalHours * PxPerHour, MinEventHeight),
        IsMultiDay = isMultiDay,
        IsStartDay = isMultiDay && date.Date == e.Item.Start.Date,
        IsEndDay = isMultiDay && e.Item.End.HasValue && date.Date == e.Item.End.Value.Date,
      };
    }).ToList();
  }

  private static int[] AssignLayers(List<(ModuleCalendarItem Item, DateTime Start, DateTime End)> clipped)
  {
    var layers = new int[clipped.Count];
    for (var i = 0; i < clipped.Count; i++)
    {
      var maxLayer = -1;
      for (var j = 0; j < i; j++)
      {
        if (clipped[i].Start < clipped[j].End && clipped[i].End > clipped[j].Start)
          maxLayer = Math.Max(maxLayer, layers[j]);
      }
      layers[i] = maxLayer + 1;
    }
    return layers;
  }

  private static string GetTimeEventTimeText(EventPosition pos)
  {
    if (pos.Item.IsDateOnly) return "";
    if (!pos.IsMultiDay)
      return $"{pos.Item.Start:H:mm} - {pos.Item.End:H:mm}";
    if (pos.IsStartDay)
      return $"{pos.Item.Start:H:mm} -";
    if (pos.IsEndDay)
      return $"- {pos.Item.End:H:mm}";
    return "";
  }

  private static string GetEventTooltip(ModuleCalendarItem item)
  {
    if (item.AllDay || item.IsDateOnly) return item.Text;
    var end = item.End?.ToString("H:mm") ?? "";
    return string.IsNullOrEmpty(end) ? $"{item.Start:H:mm} {item.Text}" : $"{item.Start:H:mm} - {end} {item.Text}";
  }

  // ===== Data classes =====

  private record CalendarDay(DateTime Date, bool IsCurrentMonth, bool IsToday);

  private class EventPosition
  {
    public ModuleCalendarItem Item { get; set; } = default!;
    public int Layer { get; set; }
    public double TopPx { get; set; }
    public double HeightPx { get; set; }
    public bool IsMultiDay { get; set; }
    public bool IsStartDay { get; set; }
    public bool IsEndDay { get; set; }
  }
}
